{
    "name": "nextjs-studio",
    "version": "1.0.3",
    "description": "A Git-based, local-first CMS for Next.js projects",
    "keywords": [
        "nextjs",
        "cms",
        "mdx",
        "content",
        "studio",
        "static-site",
        "local-first"
    ],
    "homepage": "https://github.com/TiagoDanin/Nextjs-Studio",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/TiagoDanin/Nextjs-Studio.git"
    },
    "license": "MIT",
    "author": "Tiago Danin",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/core/index.d.ts",
            "import": "./dist/core/index.js"
        },
        "./server": {
            "types": "./dist/core/server.d.ts",
            "import": "./dist/core/server.js"
        }
    },
    "main": "./dist/core/index.js",
    "types": "./dist/core/index.d.ts",
    "bin": "dist/bin/nextjs-studio.js",
    "files": [
        "dist/bin",
        "dist/core",
        "dist/*.d.ts",
        "dist/cli/ui/standalone.tar.gz",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "tsx src/bin/nextjs-studio.ts --dir example/contents --config example/studio.config.ts",
        "studio:dev": "cross-env STUDIO_CONTENTS_DIR=example/contents STUDIO_CONFIG_PATH=example/studio.config.ts next dev --port 3030 --webpack src/cli/ui",
        "studio:build": "next build --webpack src/cli/ui && node -e \"const fs=require('fs');const p='dist/cli/ui/.next/standalone/dist/cli/ui/.next';fs.mkdirSync(p,{recursive:true});fs.cpSync('dist/cli/ui/.next/static',p+'/static',{recursive:true})\" && tar czf dist/cli/ui/standalone.tar.gz -C dist/cli/ui/.next standalone",
        "build": "tsup && yarn studio:build",
        "lint": "eslint src/",
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "engines": {
        "node": ">=22.10.0"
    },
    "packageManager": "yarn@4.6.0",
    "devDependencies": {
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-switch": "^1.2.6",
        "@tailwindcss/postcss": "^4.1.18",
        "@tanstack/react-table": "^8.21.3",
        "@tiptap/extension-bubble-menu": "^3.20.0",
        "@tiptap/extension-code-block-lowlight": "^3.20.0",
        "@tiptap/extension-file-handler": "^3.20.0",
        "@tiptap/extension-image": "^3.20.0",
        "@tiptap/extension-link": "^3.20.0",
        "@tiptap/extension-placeholder": "^3.20.0",
        "@tiptap/react": "^3.20.0",
        "@tiptap/starter-kit": "^3.20.0",
        "@tiptap/suggestion": "^3.20.0",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^25.2.3",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cross-env": "^10.1.0",
        "eslint": "^10.0.0",
        "lowlight": "^3.3.0",
        "lucide-react": "^0.574.0",
        "mermaid": "^11.6.0",
        "next": "^16.1.6",
        "next-themes": "^0.4.6",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwind-merge": "^3.4.1",
        "tailwindcss": "^4.1.18",
        "tippy.js": "^6.3.7",
        "tiptap-extension-global-drag-handle": "^0.1.18",
        "tiptap-markdown": "^0.9.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18",
        "zustand": "^5.0.11"
    },
    "dependencies": {
        "@sindresorhus/slugify": "^3.0.0",
        "chokidar": "^5.0.0",
        "commander": "^14.0.3",
        "gray-matter": "^4.0.3",
        "lodash-es": "^4.17.23",
        "nanoid": "^5.1.7"
    }
}
